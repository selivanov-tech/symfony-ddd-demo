parameters:
	ignoreErrors:
		-
			message: '#^Method App\\Application\\Exception\\Abstract\\AbstractNotFoundException\:\:__construct\(\) has parameter \$headers with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Application/Exception/Abstract/AbstractNotFoundException.php

		-
			message: '#^Method App\\Application\\Request\\Customer\\AbstractBaseCustomerRequest\:\:__construct\(\) has parameter \$data with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Application/Request/Customer/AbstractBaseCustomerRequest.php

		-
			message: '#^Method App\\Domain\\Loan\\Repository\\LoanRepositoryInterface\:\:findByCustomerId\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Domain/Loan/Repository/LoanRepositoryInterface.php

		-
			message: '#^Method App\\Domain\\Product\\Entity\\Product\:\:getAvailableStates\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
